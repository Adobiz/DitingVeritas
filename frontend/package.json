{
  "name": "diting-veritas",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.diting.veritas",
    "productName": "DitingVeritas",
    "icon": "assets/icon3.png",
    "directories": { "output": "release" },
    "extraResources": [
      { "from": "../backend/dist/diting-backend.exe", "to": "backend/diting-backend.exe" }
    ],
    "win": {
      "target": "portable",
      "sign": false,
      "extraFiles": [{
        "from": "node_modules/electron/dist/ffmpeg.dll",
        "to": "./ffmpeg.dll"
      }]
    },
    "forceCodeSigning": false
  }
}
